{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Infrastructure": {
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "ClientId": "notification-processor"
    },
    "Redis": {
      "ConnectionString": "localhost:6379"
    },
    "MySql": {
      "ConnectionString": "Server=localhost;Port=3306;Database=notifications;User=root;Password=root;"
    },
    "Cassandra": {
      "ContactPoints": "localhost",
      "Port": 9042,
      "Keyspace": "notification_audit",
      "Datacenter": "datacenter1"
    },
    "Auth": {
      "Issuer": "notification-dev-issuer",
      "Audience": "notification-internal-clients",
      "SigningKey": "super-secret-dev-signing-key-with-at-least-32-chars"
    },
    "RateLimit": {
      "MaxPerWindow": 2,
      "WindowHours": 24
    },
    "Delivery": {
      "MaxRetries": 3,
      "BaseDelaySeconds": 2
    }
  }
}
