{
  "info": {
    "_postman_id": "d0b4d2ac-f3d9-4aa0-a5d2-4b3f9a9d3f01",
    "name": "TinyURL Advanced",
    "description": "Postman collection for the TinyURL advanced implementation running behind Nginx.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "longUrl",
      "value": "https://learn.microsoft.com/aspnet/core"
    },
    {
      "key": "shortCode",
      "value": "0000001"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Checks whether the load balancer and API stack are healthy."
      },
      "response": []
    },
    {
      "name": "Create URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('shortCode', json.shortCode);",
              "",
              "pm.test('shortCode is present', function () {",
              "    pm.expect(json.shortCode).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"longUrl\": \"{{longUrl}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/create-url",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "create-url"
          ]
        },
        "description": "Creates a short URL and stores the returned shortCode into the collection variable."
      },
      "response": []
    },
    {
      "name": "Resolve Short URL",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/{{shortCode}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "{{shortCode}}"
          ]
        },
        "description": "Follows the redirect for the latest shortCode captured from the Create URL request."
      },
      "response": []
    },
    {
      "name": "Resolve Short URL Without Following Redirect",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/{{shortCode}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "{{shortCode}}"
          ]
        },
        "description": "Use this request with Postman redirect-following disabled if you want to inspect the 301 response headers."
      },
      "protocolProfileBehavior": {
        "followRedirects": false
      },
      "response": []
    }
  ]
}
